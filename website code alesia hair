<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hair by Alesia — Wedding & Event Hair</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --white:#fdfcfa;
    --beige:#e9e0d2;
    --beige-dim:#f3ede1;
    --black:#1c1a17;
    --ink-soft:#4a443c;
    --pink:#e7c3c8;
    --line:rgba(28,26,23,0.13);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{background:var(--white);color:var(--black);font-family:'Jost',sans-serif;font-weight:300;line-height:1.7;}
  h1,h2,h3,.serif{font-family:'Cormorant Garamond',serif;font-weight:500;}
  a{color:inherit;text-decoration:none;}
  img{display:block;max-width:100%;}
  .wrap{max-width:1040px;margin:0 auto;padding:0 6vw;}
  .eyebrow{font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--ink-soft);}
  .rule{width:44px;height:1px;background:var(--black);margin:22px 0;}
  .rule.center{margin:22px auto;}

  header{
    position:fixed;top:0;left:0;right:0;z-index:50;
    display:flex;align-items:center;justify-content:space-between;
    padding:24px 6vw;
    background:rgba(253,252,250,0.9);
    backdrop-filter:blur(8px);
    border-bottom:1px solid transparent;
    transition:border-color 0.3s ease;
  }
  header.scrolled{border-color:var(--line);}
  .logo-mark{display:flex;align-items:baseline;gap:10px;}
  .logo{font-family:'Alex Brush',cursive;font-size:2rem;color:var(--black);line-height:1;}
  .logo-sub{font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--ink-soft);line-height:1.5;}
  nav ul{list-style:none;display:flex;gap:36px;}
  nav a{font-size:0.78rem;letter-spacing:0.08em;text-transform:uppercase;}
  .nav-cta{border:1px solid var(--black);padding:9px 20px;font-size:0.75rem;letter-spacing:0.06em;text-transform:uppercase;}
  .nav-toggle{display:none;}

  .intro-hero{padding:170px 0 40px;text-align:center;}
  .intro-hero .eyebrow{color:var(--ink-soft);}
  .intro-hero h1{font-size:clamp(2.4rem,5vw,3.4rem);font-style:italic;line-height:1.15;margin:18px 0 12px;}
  .intro-hero p{font-size:1rem;color:var(--ink-soft);}

  section{padding:110px 0;}
  .center-head{text-align:center;max-width:600px;margin:0 auto 60px;}
  .center-head h2{font-size:clamp(2rem,3.4vw,2.6rem);}

  .about-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:50px;margin-top:10px;}
  .founder h3{font-size:1.6rem;margin-bottom:4px;}
  .founder .role{font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:16px;display:block;}
  .founder p{font-size:0.92rem;color:var(--ink-soft);}

  .about-intro{display:grid;grid-template-columns:0.85fr 1fr;gap:70px;align-items:center;}
  .about-photo img{width:100%;aspect-ratio:3/4;height:auto;object-fit:cover;object-position:center;}
  .about-text .eyebrow{color:var(--ink-soft);}
  .about-text h2{font-size:clamp(2rem,3.4vw,2.6rem);margin:14px 0 18px;}
  .about-text p{font-size:1rem;color:var(--ink-soft);max-width:440px;}
  .about-note{
    margin-top:70px;padding-top:50px;border-top:1px solid var(--line);
    text-align:center;max-width:640px;margin-left:auto;margin-right:auto;
  }
  .about-note p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.4rem;color:var(--black);line-height:1.5;}

  .services{background:var(--beige-dim);}
  .service-list{max-width:720px;margin:0 auto;}
  .service-row{
    display:flex;justify-content:space-between;align-items:baseline;
    padding:26px 0;border-top:1px solid var(--line);
    gap:24px;
  }
  .service-list .service-row:last-child{border-bottom:1px solid var(--line);}
  .service-row h3{font-size:1.35rem;}
  .service-title{display:flex;flex-direction:column;gap:3px;white-space:nowrap;}
  .service-title .price{font-size:0.95rem;font-weight:600;letter-spacing:0.02em;color:var(--black);font-family:'Jost',sans-serif;}
  .service-row p{font-size:0.88rem;color:var(--ink-soft);text-align:right;max-width:420px;}

  .gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
  .gallery-grid img{width:100%;height:420px;object-fit:contain;background:var(--beige-dim);}

  .quote-block{text-align:center;max-width:680px;margin:0 auto;}
  .quote-block p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(1.4rem,2.4vw,1.9rem);color:var(--ink-soft);}
  .quote-block .who{margin-top:22px;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--black);}

  .booking{background:var(--black);color:var(--white);}
  .booking .eyebrow{color:var(--pink);}
  .booking-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:start;}
  .booking-info h2{color:var(--white);font-size:clamp(2rem,3.4vw,2.6rem);margin:16px 0 20px;}
  .booking-info p{color:rgba(253,252,250,0.72);max-width:380px;margin-bottom:26px;font-size:0.95rem;}
  .info-row{display:flex;gap:16px;padding:14px 0;border-top:1px solid rgba(253,252,250,0.16);font-size:0.88rem;}
  .info-row span:first-child{width:120px;color:var(--pink);letter-spacing:0.06em;text-transform:uppercase;font-size:0.68rem;padding-top:2px;}
  .booking-form{display:flex;flex-direction:column;gap:14px;}
  .booking-form input,.booking-form select,.booking-form textarea{
    background:transparent;border:none;border-bottom:1px solid rgba(253,252,250,0.25);
    padding:11px 2px;font-family:'Jost',sans-serif;font-size:0.92rem;color:var(--white);
  }
  .booking-form input::placeholder,.booking-form textarea::placeholder{color:rgba(253,252,250,0.45);}
  .booking-form input:focus,.booking-form select:focus,.booking-form textarea:focus{outline:none;border-color:var(--pink);}
  .booking-form label{font-size:0.66rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(253,252,250,0.55);margin-bottom:-6px;}
  .booking-form option{color:#1c1a17;}
  .btn{margin-top:8px;background:var(--white);color:var(--black);padding:14px 30px;font-size:0.78rem;letter-spacing:0.07em;text-transform:uppercase;border:none;cursor:pointer;width:fit-content;transition:background 0.3s ease,color 0.3s ease;}
  .btn:hover{background:var(--pink);}

  footer{
    padding:44px 6vw;display:flex;justify-content:space-between;align-items:center;
    background:var(--black);color:rgba(253,252,250,0.6);font-size:0.76rem;flex-wrap:wrap;gap:14px;
    border-top:1px solid rgba(253,252,250,0.12);
  }
  footer .logo{color:var(--white);font-size:1.4rem;}

  @media (max-width:820px){
    nav,.nav-cta{display:none;}
    .nav-toggle{display:block;font-size:0.76rem;letter-spacing:0.08em;text-transform:uppercase;}
    .about-grid{grid-template-columns:1fr;gap:36px;}
    .about-intro{grid-template-columns:1fr;gap:30px;text-align:center;}
    .about-photo img{max-width:340px;margin:0 auto;}
    .about-text p{margin-left:auto;margin-right:auto;}
    .gallery-grid{grid-template-columns:1fr 1fr;}
    .gallery-grid img{height:280px;object-fit:contain;}
    .booking-grid{grid-template-columns:1fr;gap:44px;}
    .service-row{flex-direction:column;gap:6px;}
    .service-title{white-space:normal;}
    .service-row p{text-align:left;}
    section{padding:70px 0;}
  }
</style>
</head>
<body>

<header id="siteHeader">
  <div class="logo-mark">
    <div class="logo-sub">Hair By</div>
    <div class="logo">Alesia</div>
  </div>
  <nav>
    <ul>
      <li><a href="#about">About</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#gallery">Gallery</a></li>
      <li><a href="#book">Book</a></li>
    </ul>
  </nav>
  <a href="#book" class="nav-cta">Free Consultation</a>
  <a href="#book" class="nav-toggle">Book</a>
</header>

<section class="intro-hero">
  <div class="wrap">
    <span class="eyebrow">Wedding · Bridesmaid · Dance · Event Hair</span>
    <h1>I do hair for your big day!</h1>
    <p>Free consultations.</p>
  </div
</section>

<section id="gallery">
  <div class="wrap">
    <div class="center-head">
      <span class="eyebrow">Style Ideas</span>
      <h2>Styles for your inspiration.</h2>
    </div>
    <div class="gallery-grid">
      <img src="data:image/jpeg;base64," alt="Curly high ponytail hairstyle">
      <img src="data:image/jpeg;base64," alt="Half-up wavy dark hairstyle">
      <img src="data:image/jpeg;base64," alt="Half-up braided wavy hairstyle">
      <img src="data:image/jpeg;base64," alt="Half-up wavy blonde hairstyle">
    </div>
  </div>
</section>

<section id="about">
  <div class="wrap">
    <div class="about-intro">
      <div class="about-photo">
        <img src="data:image/jpeg;base64," alt="Alesia Biasi, licensed cosmetologist">
      </div>
      <div class="about-text">
        <h2>Meet Alesia.</h2>
        <p>I attended cosmetology school at Taylor Andrews Academy in St. George, Utah, where I graduated after completing the program from 2022 to 2023. I am currently a student at Utah Valley University, where I am studying Marketing.</p>
      </div>
    </div>
  </div>
</section>

<section id="services" class="services">
  <div class="wrap">
    <div class="center-head">
      <span class="eyebrow">Pricing</span>
      <h2>Affordable Bridal &amp; Event Hair</h2>
    </div>
    <div class="service-list">
      <div class="service-row">
        <div class="service-title"><h3>Free Consultation</h3><span class="price">Included</span></div>
        <p>Before booking, I offer a free consultation so we can talk through your vision, your hair type, timing, and the style you're hoping for.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Wedding Day Hair</h3><span class="price">$75</span></div>
        <p>On the day of, I'll make sure your hair is beautiful, comfortable, and ready to last through the celebration.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Bridal Preview</h3><span class="price">$25</span></div>
        <p>A practice run before the wedding day so we can test your style and make sure it feels exactly right.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Bride + Preview Package</h3><span class="price">$100</span></div>
        <p>Includes your bridal preview before the wedding and your wedding day hairstyle.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Bridesmaids</h3><span class="price">$50 per person</span></div>
        <p>I create soft, coordinated styles for the bridal party so everyone feels beautiful and ready on time.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Dance &amp; Prom</h3><span class="price">$40</span></div>
        <p>I create styles that look great in photos and hold up through the whole night.</p>
      </div>
      <div class="service-row">
        <div class="service-title"><h3>Special Events</h3><span class="price">$40</span></div>
        <p>Whether it's a shower, gala, photoshoot, or celebration, I'll help you feel polished and confident for the occasion.</p>
      </div>
    </div>
  </div>
</section>

<section id="book" class="booking">
  <div class="wrap">
    <div class="booking-grid">
      <div class="booking-info">
        <span class="eyebrow">Free Consultation</span>
        <h2>Let's talk about your hair.</h2>
        <p>Every booking starts with a free consultation with Alesia — just a conversation about the look you have in mind.</p>
        <div class="info-row"><span>Based In</span><span>Utah County & Southern Utah — travel available</span></div>
        <div class="info-row"><span>Booking</span><span>4–8 weeks out for parties of 3+</span></div>
        <div class="info-row"><span>Contact</span><span>alesiambiasi@gmail.com</span></div>
      </div>
      <form class="booking-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Request Sent';">
        <label>Name</label>
        <input type="text" placeholder="Your name" required>
        <label>Email</label>
        <input type="email" placeholder="you@email.com" required>
        <label>Occasion</label>
        <select required>
          <option value="" disabled selected>Select one</option>
          <option>Wedding Day</option>
          <option>Bridesmaid Party</option>
          <option>Dance / Prom</option>
          <option>Special Event</option>
        </select>
        <label>Date &amp; Party Size</label>
        <input type="text" placeholder="e.g. Sept 12, party of 5">
        <label>Notes</label>
        <textarea rows="3" placeholder="Tell us about the look you're after"></textarea>
        <button type="submit" class="btn">Request Free Consultation</button>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="logo">Alesia</div>
  <div>© 2026 Hair by Alesia</div>
</footer>

<script>
  const header = document.getElementById('siteHeader');
  window.addEventListener('scroll', () => header.classList.toggle('scrolled', window.scrollY > 30));
</script>
</body>
</html>
